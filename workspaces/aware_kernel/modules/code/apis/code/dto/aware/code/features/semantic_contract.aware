}

/// Provider-owned capability execution policy declaration.
class CodeCapabilityExecutionPolicyDescriptor : inline_value {
    capability String
    semantic_owner String
    callable_module String?
    callable_name String?
    required_semantic_scope_keys String[] = []
    priority Int = 100
    applies_when String = "always"
}

