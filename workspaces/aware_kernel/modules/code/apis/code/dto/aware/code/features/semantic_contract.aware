class CodeSemanticContractSpecSection : inline_value {
    section_key String
    title String
    body String
    item_count Int = 0
    source_fields String[] = []
}

/// Generated reader-facing SPEC declaration derived from a Code semantic contract.
class CodeSemanticContractSpecDeclaration : inline_value {
    provider_key String
    title String
    summary String
    markdown String
    sections code.CodeSemanticContractSpecSection[] = []
    generated_code_packages code.CodeSemanticGeneratedCodePackageDeclaration[] = []
