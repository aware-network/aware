class CodeSemanticScopeResolution : inline_value {
    scope_key String
    provider_key String
    payload JsonObject = {}
    materialization_dependencies code.CodeSemanticMaterializationScopeDependency[] = []
    metadata JsonObject?
}

/// API-owned DTO for the full shared Code semantic contract.
class CodeSemanticContract : inline_value {
    provider_key String
    semantic_scope_keys String[] = []
    capability_participation code.CodeCapabilityParticipationDescriptor[] = []
    capability_execution_policy code.CodeCapabilityExecutionPolicyDescriptor[] = []
    capability_profiles code.CodeCapabilityProfileDescriptor[] = []
    capability_bundles code.CodeCapabilityBundleDescriptor[] = []
    syntax_lanes code.CodeSemanticSyntaxLaneDescriptor[] = []
    grammar_rule_declarations code.CodeSemanticGrammarRuleDescriptor[] = []
    package_roles code.CodeSemanticPackageRoleDescriptor[] = []
    semantic_workflows code.CodeSemanticWorkflowDescriptor[] = []
    artifact_leaf_ownership code.CodeSemanticArtifactLeafOwnershipDescriptor[] = []
    materialization_artifact_outputs code.CodeSemanticMaterializationArtifactOutputDescriptor[] = []
    materialization_code_package_delta_outputs code.CodeSemanticMaterializationCodePackageDeltaOutputDescriptor[] = []
    materialization_inputs code.CodeSemanticMaterializationInputDescriptor[] = []
    materialization_package_outputs code.CodeSemanticMaterializationPackageOutputDescriptor[] = []
    materialization_runtime code.CodeSemanticMaterializationRuntimeDescriptor[] = []
    materialization_runtime_context code.CodeSemanticMaterializationRuntimeContextDescriptor[] = []
    materialization_execution_context code.CodeSemanticMaterializationExecutionContextDescriptor[] = []
    manifest_resolution code.CodeSemanticManifestResolutionDescriptor[] = []
    metadata JsonObject?
}

