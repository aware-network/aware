class CodeSemanticProviderBinding : inline_value {
    provider_key String
    provider_role String?
    provider_name String?
    provider_module String?
    package_fqn String?
    manifest_kind String?
    manifest_relative_path String?
    semantic_package_metadata JsonObject?
}

/// Describe one semantic contract by provider or package coordinates.
class DescribeCodeSemanticContractRequest augment code.CodeServiceRequest {
    operation String = "describe_semantic_contract"
    provider_key String?
    package_name String?
    package_fqn String?
    include_layout Bool = true
    include_spec_declaration Bool = false
}

class DescribeCodeSemanticContractResponse augment code.CodeServiceResponse {
    operation String = "describe_semantic_contract"
    semantic_contract code.CodeSemanticContract?
    layout_contract code.CodePackageLayoutContract?
    provider_binding code.CodeSemanticProviderBinding?
    spec_declaration code.CodeSemanticContractSpecDeclaration?
}

/// Validate an externally supplied Code semantic contract DTO.
class ValidateCodeSemanticContractRequest augment code.CodeServiceRequest {
    operation String = "validate_semantic_contract"
    semantic_contract code.CodeSemanticContract
    strict Bool = true
}

class ValidateCodeSemanticContractResponse augment code.CodeServiceResponse {
    operation String = "validate_semantic_contract"
    valid Bool = false
    diagnostics String[] = []
}

/// Normalize a runtime-adapted semantic contract into the public DTO shape.
class NormalizeCodeSemanticContractRequest augment code.CodeServiceRequest {
    operation String = "normalize_semantic_contract"
    semantic_contract code.CodeSemanticContract
}

class NormalizeCodeSemanticContractResponse augment code.CodeServiceResponse {
    operation String = "normalize_semantic_contract"
    semantic_contract code.CodeSemanticContract?
}

