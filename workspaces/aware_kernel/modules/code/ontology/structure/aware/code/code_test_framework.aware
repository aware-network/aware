class CodeTestFramework {
    // Attributes
    name String key
    title String?

    fn build construct(
        name String key,
        title String? = null
    ) -> CodeTestFramework {
        """
        Create deterministic test framework identity by canonical framework name.
        """
    }
}

ann code.CodeTestFramework identity standalone
