/// Ontology GraphOS function-call DTOs.
///
/// These payloads are the public graph operation contract for services and
/// environments. Ontology service may delegate to Meta internally, but this
/// boundary is Ontology-owned.

class OntologyGraphInvokeFunctionRequest {
    actor_id UUID?
    domain_branch_id UUID?
    domain_projection_hash String?
    call_target graph.instance.OntologyGraphFunctionCallTarget = instance
    target_object_id UUID?
    object_projection_graph_id UUID?
    function_id UUID
    args JsonArray = []
    kwargs JsonObject = {}
    expected_graph_hash_pre String?
    expected_head_commit_id UUID?
    commit Bool = true
    publish Bool = false
}

class OntologyGraphInvokeFunctionResponse {
    status String
    actor_id UUID?
    domain_branch_id UUID?
    domain_projection_hash String?
    payload JsonValue?
    error String?
    logs String[] = []
    execution_time_ms Int?
    root_object_id UUID?
    graph_hash_pre String?
    graph_hash_post String?
    changes JsonArray = []
    domain_commit_id UUID?
    object_instance_graph_commit_id UUID?
    function_call_id UUID?
    function_call_response_id UUID?
    required_reactions graph.instance.OntologyRequiredReactionReceipt[] = []
    commit_event graph.instance.OntologyCommitEventEnvelope?
}

class OntologyGraphGetLaneHeadRequest {
    actor_id UUID?
    domain_branch_id UUID
    domain_projection_hash String
}

class OntologyGraphGetLaneHeadResponse {
    status String
    actor_id UUID?
    domain_branch_id UUID
    domain_projection_hash String
    error String?
    domain_commit_id UUID?
    graph_hash_post String?
    object_instance_graph_id UUID?
    root_object_id UUID?
    head_version Int?
}

class OntologyGraphGetObjectInstanceGraphCommitRequest {
    actor_id UUID?
    domain_branch_id UUID
    domain_projection_hash String
    domain_commit_id UUID
}

class OntologyGraphGetObjectInstanceGraphCommitResponse {
    status String
    actor_id UUID?
    domain_branch_id UUID?
    domain_projection_hash String?
    domain_commit_id UUID?
    object_instance_graph_commit_id UUID?
    object_instance_graph_id UUID?
    object_instance_graph_identity_id UUID?
    root_object_id UUID?
    graph_hash_pre String?
    graph_hash_post String?
    source_language String?
    commit_author_id UUID?
    commit_created_at_unix_ms Int?
    commit JsonObject?
    error String?
}

class OntologyGraphResolveProjectionRequest {
    actor_id UUID?
    projection_name String?
    projection_hash String?
    object_projection_graph_id UUID?
    include_available Bool = false
}

class OntologyGraphResolveProjectionResponse {
    status String
    actor_id UUID?
    projection_name String?
    projection_hash String?
    object_projection_graph_id UUID?
    object_projection_graph_identity_id UUID?
    object_config_graph_id UUID?
    object_config_graph_identity_id UUID?
    language String?
    supports_virtual_build Bool?
    matched_projection_hashes String[] = []
    available_projection_names String[] = []
    error String?
}
